# Health Monitor env template
#
# Copy to .env.local and fill in. Empty values mean "disabled".

# Path to the SQLite database. Default: ./data/app.db
# SQLITE_PATH=

# Optional. Comma-separated list of dev-server origins to whitelist (CORS).
# NEXT_DEV_ORIGIN=

# Wave 3 auth: shared password for the /expenses/* pages and /api/expenses/*
# APIs. Leave empty to keep the install open (local dev / single-user PWA).
# Set to any non-empty value to require a login. The login page is rendered
# at /login and the session lives in an HttpOnly cookie for 30 days.
EXPENSES_PASSWORD=

# Wave 3 worker: OCR scheduler tick interval (ms). Default 30s. Lower for
# faster retry pickup in dev, raise for production to limit DB churn.
# SCHEDULER_OCR_INTERVAL_MS=30000

# Wave 3 worker: orphan-file cleanup tick interval (ms). Default 24h. The
# cleanup scans data/expense-receipts/originals/ and thumbs/ and removes any
# file not referenced by the DB (and older than 24h, to avoid racing in-flight
# uploads).
# SCHEDULER_CLEANUP_INTERVAL_MS=86400000

# Wave 3 subscription: recurring-rules tick interval (ms). Default 1h. The
# tick scans active rules whose next_run_at has passed and posts a transaction
# for each. Lower values fire monthly rules closer to the right wall-clock
# minute, at the cost of more SQLite reads.
# SCHEDULER_RECURRING_INTERVAL_MS=3600000

# Wave 4: Bearer token for the SMS auto-entry webhook. Used by iOS Shortcuts
# to POST bank SMS alerts to /api/expenses/sms-transactions. Must be non-empty
# to enable the endpoint. Generate a strong random string and paste it into the
# Shortcuts action's Authorization header.
# EXPENSES_SMS_TOKEN=